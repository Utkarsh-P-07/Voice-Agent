# ── AI ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers → Python
# Format:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Leave blank to use local JSON file fallback (no DB needed for dev)
MONGODB_URI=
MONGODB_DB=voiceagent

# ── OAuth — Google ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub ─────────────────────────────────────────────────────────────
# Get from: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Security ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-string-32chars

# ── URLs ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
